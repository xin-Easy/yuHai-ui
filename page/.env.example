# Cloudflare Pages 环境变量模板
# ================================
# 复制此文件为 .dev.vars 用于本地开发
# 生产环境在 Cloudflare Dashboard → Pages → 设置 → 环境变量 配置

# 前端（PUBLIC_ 前缀会暴露给浏览器）
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
PUBLIC_APP_ENV=development
PUBLIC_APP_DEBUG=true
PUBLIC_APP_VERSION=1.0.0

# 后端（仅服务器端使用）
CLERK_SECRET_KEY=sk_test_your_key_here